# ─────────────────────────────────────────────────────────────────────────────
# Logto MCP Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Your self-hosted Logto instance URL (no trailing slash)
LOGTO_ENDPOINT=https://your-logto.example.com

# Machine-to-Machine application credentials
# Create an M2M app in Logto Console → Applications → Create → Machine-to-Machine
# Then assign it the "Logto Management API" resource with the "all" scope
LOGTO_APP_ID=your-m2m-app-id
LOGTO_APP_SECRET=your-m2m-app-secret

# Optional: End-user Bearer token for Accounts API tools (my-account/* endpoints)
# Obtain this by having a user sign in to your application and capturing their access token
# The token must include the "https://your-logto.example.com/api/my-account" audience
LOGTO_ACCOUNTS_TOKEN=
